program main;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.SysUtils,
  task1 in 'task1.pas',
  task2 in 'task2.pas';
var
  Input: String;
  Num: Integer;
begin
  while True do
  begin
    Write('Введите номер задания (1/2): ');
    Readln(Input);
    if not TryStrToInt(Input, Num) then
    begin
      writeln('Введите валидное число');
      continue
    end;
    if (Num > 2) or (Num < 1) then
    begin
      writeln('Неверыный номер задания');
      continue
    end;

    if Num = 1 then
      task1.Solve
    else
      task2.Solve;

  end;
end.
