unit task1;

interface

procedure Solve;

implementation

uses
  SysUtils;

{$APPTYPE CONSOLE}

type
  TCharSet = Set of Char;

const
  VOWELS = ['а', 'е', 'и', 'о', 'у', 'ы', 'э', 'ю', 'я'];

procedure Solve();
Var
  FirSet, SecSet: TCharSet;
  InpStr, Words: AnsiString;
  i, k: Integer;
begin
  i := 1;
  k := 1;
  FirSet := [];
  SecSet := [];
  Readln(InpStr);
  while InpStr[i] <> '.' do
  begin
    Words := Words + InpStr[i];
    if (InpStr[i] in VOWELS) and (InpStr[i] in FirSet) and
      ((Pos(InpStr[i], Words) + k) = i) then
    begin
      Include(SecSet, AnsiChar(InpStr[i]));
    end;
    if (InpStr[i] in VOWELS) and not(InpStr[i] in FirSet) then
    begin
      Include(FirSet, AnsiChar(InpStr[i]));
    end;
    if (InpStr[i] = ',') then
    begin
      k := i;
      Words := '';
    end;
    Inc(i);
  end;
  for i := 0 to 255 do
    if AnsiChar(i) in SecSet then
      Write(AnsiChar(i) + ';');
  writeln;
end;

end.
