program main;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils,
  task1 in 'task1.pas',
  task2 in 'task2.pas';

var
  Input: String;
  Num: Integer;

begin
  while True do
  begin
    Writeln('1 - Первое задание');
    Writeln('2 - Второе задание');
    Writeln('0 - Выйти');
    Write('Выберите: ');
    Readln(Input);
    if not TryStrToInt(Input, Num) then
    begin
      Writeln('Введите валидное число');
      continue
    end;
    case Num of
      1:
        task1.Solve;
      2:
        task2.Solve;
      0:
        break;
    else
      Writeln('Введите валидный пункт меню');
    end;
  end;

end.
