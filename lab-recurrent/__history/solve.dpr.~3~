program solve;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

var
  I, N: Integer;
  arr: array of Integer;

function CalculateNegativeMultiply(const A: array of Integer): Integer;

  function InnerRecursiveMultiply(Index: Integer): Integer;
  begin
    if Index < 0 then
      Result := 1
    else if A[Index] < 0 then
      Result := A[Index] * InnerRecursiveMultiply(Index - 1)
    else
      Result := InnerRecursiveMultiply(Index - 1);
  end;

begin
  Result := InnerRecursiveMultiply(High(A));
end;

begin
  write('┬тхфшҐх ішёыю: ');
  readln(N);
  setLength(arr, N);
  Randomize;
  for I := 0 to N - 1 do
  begin
    arr[I] := Random(100);
    Write(arr[I], ' ');
  end;
  writeln;

  writeln(CalculateNegativeMultiply(arr));

end.
